{
  "name": "vng-qa-monorepo",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm:dev:web\" \"pnpm:dev:api\"",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm --filter web build && pnpm --filter api build",
    "lint": "pnpm --filter \"*\" lint",
    "format": "pnpm --filter \"*\" format",
    "test": "pnpm --filter \"*\" test",
    "db:migrate": "cd apps/api && alembic upgrade head",
    "db:reset": "cd apps/api && alembic downgrade base && pnpm run db:migrate",
    "docker:up": "docker-compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infra/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
